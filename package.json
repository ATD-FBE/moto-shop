        "pdfmake": "^0.2.20",
        "react": "19.0.0",
        "react-dom": "19.0.0",
        "react-redux": "9.2.0",
        "react-router": "^7.6.1",
        "react-router-dom": "^7.6.1",
        "react-spinners": "^0.15.0",
        "redux": "^5.0.1",
        "sass": "^1.97.3",
        "sass-loader": "^16.0.7",
        "sharp": "^0.34.2",
        "style-loader": "^4.0.0",
