{
    "name": "magazine_app",
    "description": "React + Redux + Node.js + Express + MongoDB",
    "version": "1.0.0",
    "author": "ATD",
    "type": "module",
    "dependencies": {
        "@a2seven/yoo-checkout": "^1.1.4",
        "@aws-sdk/client-s3": "^3.1073.0",
        "@aws-sdk/lib-storage": "^3.1073.0",
        "@aws-sdk/s3-request-presigner": "^3.1073.0",
        "@babel/cli": "^7.29.7",
        "@babel/core": "^7.29.7",
        "@babel/preset-env": "^7.29.7",
        "@babel/preset-react": "^7.29.7",
        "@babel/preset-typescript": "^7.29.7",
        "@reduxjs/toolkit": "^2.12.0",
        "babel-loader": "^10.1.1",
        "bcrypt": "^6.0.0",
        "classnames": "^2.5.1",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "cross-env": "^10.1.0",
        "css-loader": "^7.1.4",
        "dayjs": "^1.11.21",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "history": "5.3.0",
        "html-react-parser": "^6.1.3",
        "immutable": "^5.1.6",
        "ip-range-check": "^0.2.0",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^9.7.2",
        "mongoose-unique-validator": "^6.1.1",
        "multer": "^2.2.0",
        "node-cron": "^4.5.0",
        "nodemon": "^3.1.14",
        "number-to-words-ru": "^2.4.1",
        "pdfmake": "^0.2.15",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "react-redux": "9.3.0",
        "react-router": "^7.18.0",
        "react-router-dom": "^7.18.0",
        "react-spinners": "^0.17.0",
        "redux": "^5.0.1",
        "sass": "^1.101.0",
        "sass-loader": "^17.0.0",
        "sharp": "^0.35.2",
        "style-loader": "^4.0.0",
        "tsx": "^4.22.4",
        "typescript": "^5.7.3",
        "webpack": "^5.107.2",
        "webpack-cli": "^7.0.3",
        "winston": "^3.19.0"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^2.1.0",
        "@types/node": "^26.0.0",
        "@types/pdfkit": "^0.17.6",
        "@types/pdfmake": "^0.2.11",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@types/supertest": "^7.2.0",
        "concurrently": "^10.0.3",
        "env-cmd": "^11.0.0",
        "jest": "^30.4.2",
        "jest-environment-jsdom": "^30.4.1",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.11",
        "webpack-dev-server": "^5.2.5"
    },
    "overrides": {
        "axios": "^1.7.0",
        "fast-xml-parser": "^5.5.6",
        "uuid": "^11.1.1"
    },
    "allowScripts": {
        "@parcel/watcher@2.5.6": true,
        "bcrypt@6.0.0": true,
        "esbuild@0.28.1": true,
        "unrs-resolver@1.12.2": true
    },
    "scripts": {
        "tsc": "tsc --noEmit",
        "test": "cross-env NODE_OPTIONS=\"--experimental-vm-modules --no-warnings\" jest",
        "start": "cross-env NODE_ENV=development concurrently \"nodemon --exec tsx server/main.ts\" \"npm run dev\" \"npm run ngrok:dev\"",
        "lan": "cross-env NODE_ENV=localnet concurrently \"nodemon --exec tsx server/main.ts\" \"npm run dev\" \"npm run ngrok:lan\"",
        "dev": "cross-env NODE_OPTIONS=\"--import tsx\" webpack serve",
        "prod": "cross-env NODE_ENV=production tsx server/main.ts",
        "build": "cross-env NODE_OPTIONS=\"--import tsx\" NODE_ENV=production webpack-cli",
        "ngrok:dev": "env-cmd -f server/config/.env.development --use-shell \"ngrok http %SERVER_PORT%\"",
        "ngrok:lan": "env-cmd -f server/config/.env.localnet --use-shell \"ngrok http %HOST%:%SERVER_PORT%\""
    }
}
