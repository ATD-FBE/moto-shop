        "winston": "^3.17.0"
    },
    "devDependencies": {
        "@babel/cli": "7.26.4",
        "@babel/preset-typescript": "^7.28.5",
        "@types/bcrypt": "^5.0.2",
        "@types/cookie-parser": "^1.4.8",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.25",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/mongodb": "^4.0.6",
        "@types/mongoose-unique-validator": "^1.0.9",
        "@types/multer": "^1.4.12",
        "@types/node": "^25.5.0",
        "@types/pdfkit": "^0.17.5",
        "@types/pdfmake": "^0.2.13",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "concurrently": "^9.1.2",
        "env-cmd": "^11.0.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "webpack-dev-server": "^5.2.3"
    },
    "overrides": {
        "axios": "^1.7.0",
        "fast-xml-parser": "^5.5.6"
    },
    "scripts": {
        "tsc": "tsc --noEmit",
        "start": "cross-env NODE_ENV=development concurrently \"nodemon --exec tsx server/main.ts\" \"npm run dev\" \"npm run ngrok:dev\"",
        "test": "cross-env NODE_ENV=testing concurrently \"nodemon --exec tsx server/main.ts\" \"npm run dev\" \"npm run ngrok:test\"",
        "prod": "cross-env NODE_ENV=production tsx server/main.ts",
        "dev": "cross-env NODE_OPTIONS=\"--import tsx\" webpack serve",
        "build": "cross-env NODE_OPTIONS=\"--import tsx\" NODE_ENV=production webpack-cli",
        "ngrok:dev": "env-cmd -f server/config/.env.development --use-shell \"cmd /c ngrok http %SERVER_PORT%\"",
        "ngrok:test": "env-cmd -f server/config/.env.testing --use-shell \"cmd /c ngrok http %HOST%:%SERVER_PORT%\""
    }
}
