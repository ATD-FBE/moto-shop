        "@babel/preset-react": "^7.28.5",
        "@reduxjs/toolkit": "^2.5.1",
        "babel-loader": "^10.0.0",
        "bcrypt": "^6.0.0",
        "classnames": "^2.5.1",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "cross-env": "^7.0.3",
        "css-loader": "^7.1.4",
        "dayjs": "^1.11.13",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "history": "5.3.0",
        "html-react-parser": "^5.2.6",
        "immutable": "^5.1.5",
        "ip-range-check": "^0.2.0",
        "jsonwebtoken": "^9.0.2",
