{
	"compilerOptions": {
		"target": "esnext",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"lib": ["esnext", "dom", "dom.iterable"],
		"jsx": "react-jsx",

		"baseUrl": ".",
		"paths": {
			"@/*": ["client/src/*"],
			"@server/*": ["server/*"],
			"@shared/*": ["shared/*"]
		},

		"strict": true,
		"noUncheckedIndexedAccess": true,
		"allowJs": true,
		"checkJs": false,
		"noEmit": true,
		"skipLibCheck": true,
		"esModuleInterop": true,

		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,
	},
	"include": [
		"client/**/*",
		"server/**/*",
		"shared/**/*"
, "client/src/components/pages/admin/customer-management/customer-table/CustomerTableBody.tsx"	],
	"exclude": [
		"node_modules",
		"client/build",
		"_logs",
		"storage"
	]
}
