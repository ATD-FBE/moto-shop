{
	"compilerOptions": {
		"target": "esnext",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"lib": ["esnext", "dom", "dom.iterable"],
		"jsx": "react-jsx",

		"baseUrl": ".",
		"paths": {
			"@/*": ["client/src/*"],
			"@server/*": ["server/*"],
			"@shared/*": ["shared/*"]
		},

		"strict": true,
		"noUncheckedIndexedAccess": true,
		"noEmit": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"sourceMap": true
	},
	"include": [
		"client/**/*",
		"server/**/*",
		"shared/**/*"
	],
	"exclude": [
		"node_modules",
		"client/build",
		"_logs",
		"storage"
	]
}
