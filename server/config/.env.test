# Данные соединения
PROTOCOL=http
HOST=localhost
DOMAIN=localhost
CLIENT_PORT=3000
SERVER_PORT=3001

# Ключи токенов доступа и обновления при авторизации
JWT_ACCESS_SECRET_KEY=qqq
JWT_REFRESH_SECRET_KEY=www

# Код для регистрации администратора
ADMIN_REG_CODE=admin-code

# Режим MongoDB: локальная база данных MongoDB
MONGO_MODE=test

# Адрес URI MongoDB
MONGO_URI_TEST=mongodb://localhost:27017/motoshopdb_test

# Тип хранилища файлов: локальная файловая система или облачное хранилище s3
STORAGE_TYPE=fs

# Данные онлайн-провайдера ЮKassa
YOOKASSA_SHOP_ID=1234567
YOOKASSA_SECRET_KEY=test_secret_key
